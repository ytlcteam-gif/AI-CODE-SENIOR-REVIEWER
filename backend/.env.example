# ─── Gemini AI ──────────────────────────────────────────────────────────────────
# Get your key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ─── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Two formats:
#   Exact:    https://ai-code-reviewer.vercel.app
#   Wildcard: *.vercel.app  (covers ALL Vercel preview deployment URLs)
#
# Local dev:
#   ALLOWED_ORIGIN=http://localhost:3000
#
# Production (set this in Railway dashboard — NOT here):
#   ALLOWED_ORIGIN=https://ai-code-reviewer.vercel.app,*.vercel.app
ALLOWED_ORIGIN=http://localhost:3000

# ─── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

# ─── AI Request Config ───────────────────────────────────────────────────────────
AI_REQUEST_TIMEOUT_MS=30000
MAX_CODE_LENGTH=10000
